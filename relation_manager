def get_non_empty_input(prompt):
    while True:
        value = input(prompt).strip()
        if value:
            return value
        print("\n This field cannot be empty. Please try again.\n")
        
def email_struct(email):    
    if len (email)>=6 and  email[0].isalpha(): # invalid 1 &  #invalid 2
        if '@' in email and (email.count('@')==1): #invalid 3 
            if (email[-4]==".") or(email[-3]=="."): # invalid 4  
                if not any(i.isspace()for i in email):             
                    return True
    return False
            
        
def phone_no(user_phone_no):
                   
            lst=user_phone_no.split()#split()is used to seperate the list 
