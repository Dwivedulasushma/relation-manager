def get_reverse_relation(relation):
    relation = relation.strip().lower()
    row = main_curr.execute(" SELECT  male_opposite, female_opposite FROM all_relation WHERE relation_name = ?", (relation,)).fetchone()
    if row:
        male_opposite, female_opposite = row
        return {
            "male_opposite": male_opposite,
            "female_opposite": female_opposite
        }
    return None


